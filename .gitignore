# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Data & results ────────────────────────────────────────────────────────────
# Large result files — host on Zenodo instead
data/results/
data/*.json
data/*.csv
data/*.pkl
data/*.h5
data/*.hdf5

# Keep gitkeep sentinels and the data README
!data/.gitkeep
!data/README.md

# ── Models & checkpoints ──────────────────────────────────────────────────────
*.pt
*.pth
*.ckpt
*.safetensors
checkpoints/
models/

# ── Figures (generated) ───────────────────────────────────────────────────────
# Final publication figures are tracked; intermediate/dev PNGs are not.
figures/tmp/
figures/dev/
*.png
!figures/*.png
!figures/*.pdf

