paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.toc
paper/*.lof
paper/*.lot
paper/_minted*/
paper/auto/

# ── Secrets & credentials ─────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
secrets.yaml
secrets.json
config/local.yaml
*api_key*
*apikey*
*secret*

